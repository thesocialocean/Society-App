rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Global Catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Residents collection
    match /residents/{residentId} {
      allow read: if true; // Open read for residents to check profile/auth verification
      allow write: if true; // Admin-level manipulation
    }

    // Payments collection
    match /payments/{paymentId} {
      allow read: if true; // Displaying history for residents / admin
      allow create, update: if true; // Submitting payments / Verification approval
      allow delete: if false; // Payments should never be deleted for audits
    }

    // Receipts collection
    match /receipts/{receiptId} {
      allow read: if true; // Residents and admin viewing
      allow write: if true; // Generated automatically
    }

    // Complaints collection
    match /complaints/{complaintId} {
      allow read: if true; // Viewing complaints
      allow create, update: if true; // Residents filing, admin updating status
      allow delete: if true; // Residents/admin cleanup
    }

    // Notices collection
    match /notices/{noticeId} {
      allow read: if true; // Read notices
      allow write: if true; // Admin creating notices
    }

    // ReminderLogs collection
    match /reminderLogs/{logId} {
      allow read, write: if true; // Tracking automatic notifications logs
    }
  }
}
